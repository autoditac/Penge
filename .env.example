# Local development environment. Copy to `.env` and fill in.
# `.env` is gitignored; `.env.example` is committed with safe defaults.

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=penge
POSTGRES_PASSWORD=changeme-locally-only
POSTGRES_DB=penge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- App ----------------------------------------------------------------------
PENGE_LOG_LEVEL=INFO
PENGE_ENV=dev

# --- External services (filled in once connectors land) -----------------------

# --- Observability (issue #52) -------------------------------------------------
# Uptime Kuma "Push" monitor URL prefix. Each ingestion job appends its slug
# (the random token Uptime Kuma generates per monitor) and pings on success:
# `${PENGE_UPTIME_KUMA_PUSH_URL}/<slug>?status=up&msg=ok&ping=`.
# Leave unset to disable heartbeats (no-op).
# PENGE_UPTIME_KUMA_PUSH_URL=https://uptime.example.invalid/api/push

# Sentry DSN for ingestion error reporting. Leave unset to disable (no-op).
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=dev
# SENTRY_RELEASE=
