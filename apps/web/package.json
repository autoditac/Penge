{
  "name": "@penge/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Penge WebUI — reporting-first household finance cockpit.",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "vite --host 127.0.0.1",
    "generate:api": "openapi-typescript ../../docs/api/openapi.json -o src/api/schema.d.ts && prettier --write src/api/schema.d.ts",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.0",
    "echarts": "6.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "7.17.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.61.1",
    "eslint": "10.3.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.59.3",
    "vite": "6.4.2",
    "vitest": "4.1.6"
  }
}
