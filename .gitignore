# Local data — never commit
data/
*.duckdb
*.duckdb.wal
*.parquet
*.csv
*.xlsx
*.ods
*.pdf
!docs/**/*.pdf
!tests/**/fixtures/**

# Monthly report artefacts (issue #50). The generator writes both PDF
# and Markdown plus PNG charts under reports/{YYYY-MM}/; none of those
# files belong in git — they may contain aggregated financial figures.
reports/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.age
secrets/
!secrets/*.enc.*

# Encrypted backups (artefacts produced by scripts/backup.sh and
# scripts/snapshot.sh). The age-encrypted blobs are themselves
# safe-ish, but their existence in the working tree implies a real
# database and is never something we want to commit. The matching
# `.sha256` sidecars and the `.scratch-*` working dirs go with them.
backups/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.egg-info/
dist/
build/

# Node / TS
node_modules/
.pnpm-store/
*.tsbuildinfo
.next/
.turbo/

# dbt
dbt_packages/
target/
logs/

# Editor / OS
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.example.json
.DS_Store
Thumbs.db
*.swp

# Misc
*.log
.cache/
.direnv/

# MkDocs build output (deployed via gh-pages branch in CI; see workflows/docs.yml)
site/

# Local connector configs — only the *.example.yaml templates are committed.
/config/*.yaml
!/config/*.example.yaml

# Chat-history dumps from coding-agent sessions may contain salary numbers,
# real account references, or other personal data — keep them out of the repo.
.github/CHAT-HISTORY.MD
.github/CHAT-HISTORY.md
# test
