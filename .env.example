# Local development environment. Copy to `.env` and fill in.
# `.env` is gitignored; `.env.example` is committed with safe defaults.

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=penge
POSTGRES_PASSWORD=changeme-locally-only
POSTGRES_DB=penge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- App ----------------------------------------------------------------------
PENGE_LOG_LEVEL=INFO
PENGE_ENV=dev

# --- External services (filled in once connectors land) -----------------------
# GOCARDLESS_SECRET_ID=
